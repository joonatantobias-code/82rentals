# 82Rentals environment variables
#
# Copy this file to .env.local for local development and set the values in
# Vercel project settings for production. None of these are required for the
# site to deploy, but each unlocks more functionality.

# CRM webhook (optional). When set, /api/book forwards bookings here.
# Until you set this, bookings are logged to Vercel runtime logs only.
# CRM_WEBHOOK_URL=https://crm.example.com/api/bookings
# CRM_API_KEY=replace-me

# Admin endpoint protection (optional). When set, /api/admin/* requires the
# `x-admin-key` header to match. Use any long random string.
# ADMIN_API_KEY=replace-with-long-random-string

# Email forwarding (optional). When you wire your provider of choice
# (Resend / SendGrid / Postmark) into /api/book, set the API key here.
# RESEND_API_KEY=re_...
# BOOKINGS_NOTIFY_EMAIL=82rentals.info@gmail.com
